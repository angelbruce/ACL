<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<!--大语言模型LLM配置，可以配置多个，只有1个是默认的-->
	<llm-config name="llm" type="ACL.business.llm.LLMAnt,ACL">
		<llmCollection>
			<llm
				name="supergemma4-26b-uncensored-fast-v2-Q4_K_M"
				accessUrl="http://localhost:18088/v1"
				apiKey ="llama"
				default="1"
				version="gemma4"
				description="这个是破解版的gemma4-26b量化版本"
				></llm>
		</llmCollection>
	</llm-config>

	<!--提示词设置，用来初始化-->
	<promptAnt name="prompt" type="ACL.business.prompt.PromptAnt,ACL">
		<prompts>
			<prompt usage="Plan" type="System" path="prompt/plan.txt"></prompt>
			<prompt usage="Code" type="System" path="prompt/coding-3.txt"></prompt>
		</prompts>
	</promptAnt>
	
	<!--配置STDIO-MCP工具服务提供者，后续要全部替换掉成为LOCAL的，这些外部的有性能问题-->
