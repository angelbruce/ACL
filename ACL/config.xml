		</stdio-mcp-collection>
	</stdio-mcp-config>
	
	<!--默认项目设置，定义项目位置-->
	<project name="project-config" type="ACL.business.project.ProjectAnt,ACL">
		<projectCollection>
			<project name="" directory="" description=""></project>
		</projectCollection>
	</project>

	<!--数据库驱动设置-->
	<database-ant name="databaseDriver" type="ABL.Data.DbDriverConfigAnt,ABL">
		<databaseCollection>
			<database name="default" 
					  provider="ACL.dao.SQLiteDbDriver,ACL" 
					  connectionString="Data Source=./acl.db;Mode=ReadWrite;Foreign Keys=True;Default Timeout=20;"></database>
		</databaseCollection>
	</database-ant>

</configuration>