				</passed-tools>
			</stdio-mcp>
			<stdio-mcp name="filesystem" command="npx">
				<args>
					<arg name="-y"></arg>
					<arg name="@modelcontextprotocol/server-filesystem"></arg>
					<arg name="j:/"></arg>
				</args>
				<passed-tools>
					<tool name="list_allowed_directories"></tool>
					<tool name="list_directory"></tool>
